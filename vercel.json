{
  "version": 2,
  "buildCommand": null,
  "outputDirectory": ".",
  "framework": null,
  "redirects": [

    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.jzzai.cn"
        }
      ],
      "destination": "https://jzzai.cn/$1",
      "statusCode": 301
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/about",
      "destination": "/about.html"
    },
    {
      "source": "/tool/:id",
      "destination": "/detail.html?tool=:id"
    },
    {
      "source": "/blog",
      "destination": "/article.html"
    },
    {
      "source": "/blog/:id",
      "destination": "/article.html?id=:id"
    }
  ]
}